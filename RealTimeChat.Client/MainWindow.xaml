<Window x:Class="RealTimeChat.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RealTimeChat.Client"
        mc:Ignorable="d"
        Title="Real-Time Chat" Height="600" Width="900"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="Settings" Click="SettingsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="ExitMenuItem_Click"/>
            </MenuItem>
            <MenuItem Header="Connection">
                <MenuItem x:Name="ReconnectMenuItem" Header="Reconnect" Click="ReconnectMenuItem_Click"/>
                <MenuItem x:Name="DisconnectMenuItem" Header="Disconnect" Click="DisconnectMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <StatusBar Grid.Row="1" Background="#F0F0F0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="User: " FontWeight="Bold"/>
                    <TextBlock x:Name="UsernameStatusText" Text=""/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusIndicator" Width="10" Height="10" 
                             Fill="Gray" Margin="0,0,5,0"/>
                    <TextBlock x:Name="ConnectionStatusText" Text="Connecting..."/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="ConnectionTypeText" Text="WebSocket"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Chat Messages Area -->
        <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" Margin="10,5,10,5">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="MessagesItemsControl" Margin="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,5,0,5" Padding="10" 
                                    Background="#F5F5F5" 
                                    CornerRadius="5">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding SenderName}" 
                                                   FontWeight="Bold" 
                                                   Foreground="#0066CC"/>
                                        <TextBlock Text=" - " Margin="5,0,5,0"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" 
                                                   Foreground="Gray" 
                                                   FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Text}" 
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Message Input Area -->
        <Grid Grid.Row="3" Margin="10,5,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="MessageTextBox" 
                     Grid.Column="0"
                     FontSize="14" 
                     Padding="8"
                     VerticalContentAlignment="Center"
                     MaxLength="1000"
                     KeyDown="MessageTextBox_KeyDown"
                     IsEnabled="False"/>

            <Button x:Name="SendButton" 
                    Grid.Column="1"
                    Content="Send" 
                    Width="100" 
                    Height="35"
                    Margin="10,0,0,0"
                    FontSize="14"
                    IsEnabled="False"
                    Click="SendButton_Click"/>
        </Grid>
    </Grid>
</Window>