<Window x:Class="RealTimeChat.Client.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="400" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" 
                   FontSize="20" FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Username:" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" x:Name="UsernameTextBox" 
                 FontSize="14" Padding="5"
                 MaxLength="100"
                 Margin="0,0,0,20"/>

        <TextBlock Grid.Row="3" Text="Connection Type:" Margin="0,0,0,10"/>
        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <RadioButton x:Name="WebSocketRadioButton" 
                         Content="WebSocket (Real-time)" 
                         IsChecked="True"
                         Margin="0,0,0,10"/>
            <RadioButton x:Name="RestApiRadioButton" 
                         Content="REST API (Polling)"
                         Margin="0,0,0,10"/>
        </StackPanel>

        <TextBlock Grid.Row="5" x:Name="NoteTextBlock" 
                   Text="Note: Changing connection type will require reconnecting to the chat."
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   FontStyle="Italic"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Save" Width="80" Height="30" 
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Click="SaveButton_Click"/>
            <Button Content="Cancel" Width="80" Height="30"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
